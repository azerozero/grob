# Oversized or malformed Authorization header must not crash the server.
# Sends a very long bearer token (~4KB of padding) to verify graceful
# rejection. The server should return 401 without panicking.
POST http://{{host}}/v1/chat/completions
Authorization: Bearer eyJhbGciOiJFUzI1NiJ9..invalidsignaturepadding
Content-Type: application/json
file,fixtures/chat-simple.json;
HTTP 401
[Asserts]
jsonpath "$.error.type" exists

# Follow-up: server still healthy after oversized token.
GET http://{{host}}/health
HTTP 200
